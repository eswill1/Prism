# Prism Wire runtime
NODE_ENV=development
PRISM_PUBLIC_SITE_URL=http://127.0.0.1:3002

# Doppler baseline
DOPPLER_PROJECT=prism-wire
DOPPLER_CONFIG=dev

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
DIRECT_DATABASE_URL=

# Upstash
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Feature flags
LIVE_FEED_ENABLED=true
NEXT_PUBLIC_PRISM_READER_EMAIL_AUTH_MODE=magic_link
